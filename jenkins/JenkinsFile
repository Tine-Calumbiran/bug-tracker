pipeline {
    agent {
        docker {
            image 'snakee/golang-junit:1.21'
            reuseNode true
        }
    }

    environment {
        GOCACHE = "/tmp/go-build"
    }

    stages {
        stage('Build') {
            steps { 
                dir('bugtracker-backend') {
                    sh '''
                        mkdir -p $GOCACHE
                        go env GOCACHE
                        go build ./...
                    '''
                }
            }
        }

        stage('Unit Tests - Backend') {
            steps {
                dir('bugtracker-backend') {
                    sh '''
                        mkdir -p $GOCACHE
                        go env GOCACHE
                        go test -v ./...
                    '''
                }
            }
        }
    }
}